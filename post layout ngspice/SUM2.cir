Vdd vdd gnd 1.8

Va0 a0 gnd 1.8
Va1 a1 gnd 1.8
Va2 a2 gnd 1.8
Va3 a3 gnd 1.8
Va4 a4 gnd 1.8

Vb0 b0 gnd PULSE(0 1.8 20n 0 0 5n 10n)
Vb1 b1 gnd 0
Vb2 b2 gnd 0
Vb3 b3 gnd 0
Vb4 b4 gnd 0
Vcin cin gnd 0

.control
tran 0.1n 50n
*plot v(a0) v(a1)+2 v(a2)+4 v(a3)+6 v(a4)+8 
plot v(b0) 
*v(b1)+2 v(b2)+4 v(b3)+6 v(b4)+8 
plot v(S1) v(S2)+2 v(S3)+4 v(S4)+6 v(S5)+8 
plot v(c5)

* Propagation delay: t(50% of cout) - t(50% of b0)
meas tran t_b0_50_rise  WHEN v(b0)=0.9 RISE=1
meas tran t_cout_50_rise  WHEN v(c5)=0.9 RISE=1
print (-t_b0_50_rise+t_cout_50_rise)
meas tran t_b0_50_fall  WHEN v(b0)=0.9 FALL=1
meas tran t_cout_50_fall  WHEN v(c5)=0.9 FALL=1
print (-t_b0_50_fall+t_cout_50_fall)
run

 t_b0_50_rise        =  2.005000e-08
 t_cout_50_rise      =  2.065100e-08
 t_b0_50_fall        =  2.515000e-08
 t_cout_50_fall      =  2.575381e-08
 Propagation delay results:
 Rise delay  = t_cout_50_rise - t_b0_50_rise = 601.00 psec
 Fall delay  = t_cout_50_fall - t_b0_50_fall = 603.81 psec

 .endc
.end

